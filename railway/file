# Railway deployment configuration
# Dockerfile is at: railway/Dockerfile
# Set all variables below in Railway → Service → Variables

service:
  name: umakraft-umamoe
  type: docker

build:
  dockerfilePath: railway/Dockerfile

deploy:
  command: node server.js
  healthcheckPath: /
  restartPolicy: ON_FAILURE

env:
  # ── Required ──────────────────────────────────────────────────────────────
  DISCORD_BOT_TOKEN:
    description: Discord bot token (Bot → Token in Developer Portal)
    required: true

  DISCORD_APPLICATION_ID:
    description: Discord application / client ID (General Information → Application ID)
    required: true

  DISCORD_GUILD_ID:
    description: Discord server / guild ID where slash commands are registered
    required: true

  DISCORD_PUBLIC_KEY:
    description: Ed25519 public key for webhook signature verification (General Information → Public Key)
    required: true

  # ── Optional (have defaults) ───────────────────────────────────────────────
  UMAMOE_API_URL:
    description: Uma.moe API base URL
    required: false
    default: https://uma.moe/api

  NODE_ENV:
    description: Node environment
    required: false
    default: production

  PORT:
    description: HTTP port the server listens on
    required: false
    default: "3000"
