# Discord application credentials (required)
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here

# uma.moe official API key (required for profile/stadium data)
# Obtain from https://uma.moe — sent as X-API-Key on all API requests.
UMA_MOE_API_KEY=your-api-key-here

# Uma.moe circle to track
CIRCLE_ID=974470619

# Optional: restrict slash command registration to a single guild for instant updates.
# Leave empty to register globally (takes up to 1 hour to propagate).
GUILD_ID=

# Optional: override the channel names the bot auto-creates for scheduled posts
ANNOUNCEMENT_CHANNEL=announcement
RESULTS_CHANNEL=result-contribution

# Optional: where the bot stores its JSON data (default: ./data)
# On Railway, point this at a mounted Volume for persistence (e.g. /data)
DATA_DIR=./data

# Optional: timezone for scheduled tasks (default: Asia/Tokyo)
TIMEZONE=Asia/Tokyo

# Optional: log level (debug | info | warn | error)
LOG_LEVEL=info
